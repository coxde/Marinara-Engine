{
  "name": "rpg-engine",
  "version": "0.1.0",
  "private": true,
  "description": "AI Chat & Roleplay Frontend \u2014 Conversation, Roleplay, Visual Novel",
  "author": "Marianna",
  "license": "AGPL-3.0",
  "type": "module",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "pnpm build:shared && pnpm --filter @rpg-engine/server --filter @rpg-engine/client -r --parallel run dev",
    "dev:server": "pnpm --filter @rpg-engine/server dev",
    "dev:client": "pnpm --filter @rpg-engine/client dev",
    "build": "pnpm --filter @rpg-engine/shared build && pnpm -r --parallel run build",
    "build:shared": "pnpm --filter @rpg-engine/shared build",
    "build:server": "pnpm --filter @rpg-engine/server build",
    "build:client": "pnpm --filter @rpg-engine/client build",
    "lint": "pnpm -r run lint",
    "test": "pnpm -r run test",
    "db:push": "pnpm --filter @rpg-engine/server db:push",
    "db:generate": "pnpm --filter @rpg-engine/server db:generate",
    "db:migrate": "pnpm --filter @rpg-engine/server db:migrate",
    "clean": "pnpm -r run clean && rm -rf node_modules"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}